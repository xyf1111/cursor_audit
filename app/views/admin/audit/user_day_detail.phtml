<?php
$summary = is_array($summary ?? null) ? $summary : [];
$detail_list = $detail_list ?? [];
$stat_date = (string) ($stat_date ?? '');
$user_name = (string) ($user_name ?? '');

$h = static function ($value): string {
    return htmlspecialchars((string) $value, ENT_QUOTES, 'UTF-8');
};

$list_query = http_build_query(array_filter([
    'user_name' => $user_name,
    'start_date' => $stat_date,
    'end_date' => $stat_date,
], static function ($value) {
    return $value !== '';
}));
?>
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <title>用户日明细</title>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; margin: 24px; color: #1f2937; }
        h1 { margin-bottom: 16px; }
        .actions { margin-bottom: 16px; }
        .actions a { color: #2563eb; text-decoration: none; margin-right: 14px; }
        .card { border: 1px solid #e5e7eb; border-radius: 8px; padding: 20px; background: #fff; margin-bottom: 20px; }
        .summary-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 12px; }
        .summary-item { background: #f9fafb; border-radius: 8px; padding: 12px 14px; }
        .label { display: block; color: #6b7280; font-size: 13px; margin-bottom: 6px; }
        .value { font-size: 16px; font-weight: 600; }
        table { width: 100%; border-collapse: collapse; background: #fff; }
        th, td { border: 1px solid #e5e7eb; padding: 10px; text-align: left; vertical-align: top; font-size: 14px; }
        th { background: #f3f4f6; }
        .prompt { max-width: 420px; white-space: pre-wrap; word-break: break-word; }
        .muted { color: #6b7280; }
    </style>
</head>
<body>
    <h1>用户日明细</h1>
    <div class="actions">
        <a href="/admin/audit">返回列表</a>
        <?php if ($list_query !== ''): ?>
            <a href="/admin/audit?<?= $h($list_query) ?>">查看筛选列表</a>
        <?php endif; ?>
    </div>

    <?php if (empty($summary) && empty($detail_list)): ?>
        <div class="card">未找到对应的用户日明细数据。</div>
    <?php else: ?>
        <div class="card">
            <div class="summary-grid">
                <div class="summary-item">
                    <span class="label">用户名</span>
                    <span class="value"><?= $h($summary['user_name'] ?? $user_name) ?></span>
                </div>
                <div class="summary-item">
                    <span class="label">统计日期</span>
                    <span class="value"><?= $h($summary['stat_date'] ?? $stat_date) ?></span>
                </div>
                <div class="summary-item">
                    <span class="label">请求次数</span>
                    <span class="value"><?= $h((int) ($summary['request_count'] ?? 0)) ?></span>
                </div>
                <div class="summary-item">
                    <span class="label">输入 Token</span>
                    <span class="value"><?= $h((int) ($summary['input_tokens'] ?? 0)) ?></span>
                </div>
                <div class="summary-item">
                    <span class="label">输出 Token</span>
                    <span class="value"><?= $h((int) ($summary['output_tokens'] ?? 0)) ?></span>
                </div>
                <div class="summary-item">
                    <span class="label">总 Token</span>
                    <span class="value"><?= $h((int) ($summary['total_tokens'] ?? 0)) ?></span>
                </div>
                <div class="summary-item">
                    <span class="label">首次使用时间</span>
                    <span class="value"><?= $h($summary['first_used_at'] ?? '') ?></span>
                </div>
                <div class="summary-item">
                    <span class="label">最后使用时间</span>
                    <span class="value"><?= $h($summary['last_used_at'] ?? '') ?></span>
                </div>
            </div>
        </div>

        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>请求时间</th>
                    <th>项目名</th>
                    <th>模型</th>
                    <th>输入 Token</th>
                    <th>输出 Token</th>
                    <th>Prompt 摘要</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
            <?php if (empty($detail_list)): ?>
                <tr>
                    <td colspan="8" class="muted">暂无明细数据</td>
                </tr>
            <?php else: ?>
                <?php foreach ($detail_list as $item): ?>
                    <tr>
                        <td><?= $h($item->id) ?></td>
                        <td><?= $h($item->created_at) ?></td>
                        <td><?= $h($item->project_name) ?></td>
                        <td><?= $h($item->model_name) ?></td>
                        <td><?= $h((int) $item->input_tokens) ?></td>
                        <td><?= $h((int) $item->output_tokens) ?></td>
                        <td class="prompt"><?= $h(mb_substr((string) $item->prompt, 0, 120)) ?><?= mb_strlen((string) $item->prompt) > 120 ? '...' : '' ?></td>
                        <td><a href="/admin/audit/detail?id=<?= $h($item->id) ?>">查看详情</a></td>
                    </tr>
                <?php endforeach; ?>
            <?php endif; ?>
            </tbody>
        </table>
    <?php endif; ?>
</body>
</html>
