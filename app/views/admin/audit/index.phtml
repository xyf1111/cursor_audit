        input { margin-top: 6px; padding: 8px 10px; min-width: 180px; border: 1px solid #d1d5db; border-radius: 6px; }
        button, .link-btn { margin-top: 24px; padding: 9px 14px; border: 0; border-radius: 6px; background: #2563eb; color: #fff; cursor: pointer; text-decoration: none; display: inline-block; }
        .link-btn.secondary { background: #6b7280; }
        .summary { margin-bottom: 12px; color: #4b5563; }
        table { width: 100%; border-collapse: collapse; background: #fff; }
