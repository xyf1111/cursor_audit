        </label>
        <label>
            开始日期
            <input type="date" name="start_date" value="<?= $h($filters['start_date'] ?? '') ?>">
        </label>
        <label>
            结束日期
            <input type="date" name="end_date" value="<?= $h($filters['end_date'] ?? '') ?>">
        </label>
        <label>
            关键词
            <input type="text" name="keyword" value="<?= $h($filters['keyword'] ?? '') ?>">
        </label>
        <input type="hidden" name="page_size" value="<?= $h($pageSize) ?>">
        <button type="submit">查询</button>
        <a class="link-btn secondary" href="/admin/audit">重置</a>
    </form>

    <div class="summary">
        共 <?= $h($total) ?> 条，当前第 <?= $h($page) ?> / <?= $h($totalPages) ?> 页
    </div>

    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>请求时间</th>
                <th>用户名</th>
                <th>事件类型</th>
                <th>项目名</th>
                <th>模型</th>
                <th>会话ID</th>
                <th>输入 Token</th>
                <th>输出 Token</th>
                <th>Prompt 摘要</th>
                <th>操作</th>
            </tr>
        </thead>
        <tbody>
        <?php if (empty($list)): ?>
            <tr>
                <td colspan="10" class="muted">暂无数据</td>
            </tr>
        <?php else: ?>
            <?php foreach ($list as $item): ?>
                <tr>
                    <td><?= $h($item->id) ?></td>
                    <td><?= $h($item->created_at) ?></td>
                    <td><?= $h($item->user_name ?: 'unknown') ?></td>
                    <td><?= $h($item->event_type) ?></td>
                    <td><?= $h($item->project_name) ?></td>
                    <td><?= $h($item->model_name) ?></td>
                    <td><?= $h($item->session_id) ?></td>
                    <td><?= $h((int) $item->input_tokens) ?></td>
                    <td><?= $h((int) $item->output_tokens) ?></td>
                    <td class="prompt"><?= $h(mb_substr((string) $item->prompt, 0, 120)) ?><?= mb_strlen((string) $item->prompt) > 120 ? '...' : '' ?></td>
                    <td><a href="/admin/audit/detail?id=<?= $h($item->id) ?>">查看详情</a></td>
                </tr>
            <?php endforeach; ?>
        <?php endif; ?>
        </tbody>
    </table>

    <div class="pager">
        <?php if ($page > 1): ?>
            <a class="link-btn secondary" href="/admin/audit?<?= $h($buildQuery(['page' => $page - 1])) ?>">上一页</a>
        <?php endif; ?>
        <?php if ($page < $totalPages): ?>
            <a class="link-btn" href="/admin/audit?<?= $h($buildQuery(['page' => $page + 1])) ?>">下一页</a>
        <?php endif; ?>
    </div>
