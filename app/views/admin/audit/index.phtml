    <form method="get" action="/admin/audit">
        <label>
            用户名
            <input type="text" name="user_name" value="<?= $h($filters['user_name'] ?? '') ?>">
        </label>
        <label>
            事件类型
            <input type="text" name="event_type" value="<?= $h($filters['event_type'] ?? '') ?>">
        </label>
        <label>
            项目名
            <input type="text" name="project_name" value="<?= $h($filters['project_name'] ?? '') ?>">
        </label>
        <label>
            模型名
