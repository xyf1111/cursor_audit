<?php
$filters = is_array($filters ?? null) ? $filters : [];
$result = is_array($result ?? null) ? $result : [];
$list = $result['list'] ?? [];
$page = (int) ($result['page'] ?? 1);
$totalPages = (int) ($result['totalPages'] ?? 1);
$pageSize = (int) ($result['pageSize'] ?? 20);
$total = (int) ($result['total'] ?? 0);

$h = static function ($value): string {
    return htmlspecialchars((string) $value, ENT_QUOTES, 'UTF-8');
};

$buildQuery = static function (array $params) use ($filters, $pageSize): string {
    $query = array_merge($filters, ['page_size' => $pageSize], $params);
    return http_build_query(array_filter($query, static function ($value) {
        return $value !== '' && $value !== null;
    }));
};
?>
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <title>AI 审计请求明细</title>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; margin: 24px; color: #1f2937; }
